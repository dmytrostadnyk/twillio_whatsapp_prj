# ══════════════════════════════════════════════════════════════════════════════
#  ENVIRONMENT VARIABLES — copy this file to .env and fill in your values
#  NEVER commit .env to git — it's already in .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ── Twilio ────────────────────────────────────────────────────────────────────
# Find these in your Twilio Console dashboard (console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# The phone number Twilio assigned you, in E.164 format (+15551234567)
TWILIO_PHONE_NUMBER=+15551234567
# WhatsApp sandbox number (use whatsapp:+14155238886 for Twilio sandbox)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL from: Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
# Service-role key (bypasses RLS — keep this secret!)
# Found at: Supabase dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Direct Postgres connection string for asyncpg (raw SQL queue operations)
# Found at: Supabase dashboard → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:your_password@db.your-project-ref.supabase.co:5432/postgres

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Get your key at: platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# ── Cohere ────────────────────────────────────────────────────────────────────
# Get your key at: dashboard.cohere.com
COHERE_API_KEY=your-cohere-key-here

# ── Mock Azure CRM ────────────────────────────────────────────────────────────
# URL where the mock CRM is running (change port if needed)
AZURE_CRM_URL=http://localhost:8001

# ── AI kill switch ────────────────────────────────────────────────────────────
# Set to "false" to instantly halt ALL AI calls (OpenAI Whisper, GPT-4o, Cohere).
# The communication layer continues working normally — only AI work stops.
# Use this if you see unexpected costs or want to test the system without AI.
AI_ENABLED=true

# ── Retry / backoff tuning ────────────────────────────────────────────────────
# How many times to retry delivering an event to Azure before giving up
DELIVERY_MAX_ATTEMPTS=8
# Starting delay in seconds for the first retry (doubles each attempt + jitter)
DELIVERY_BACKOFF_BASE_SECONDS=5
# How often the delivery worker polls for new events (in seconds)
DELIVERY_POLL_INTERVAL_SECONDS=5

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Max AI enrichment tasks running at the same time (to respect OpenAI limits)
ENRICHMENT_CONCURRENCY=3
# Max outbound messages per minute (to respect Twilio limits)
OUTBOUND_RATE_LIMIT_PER_MINUTE=5

# ── Application ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Your ngrok public URL (update this each time ngrok restarts)
# Example: https://abc123.ngrok-free.app
PUBLIC_BASE_URL=https://your-ngrok-url.ngrok-free.app

# ── Voice recording ───────────────────────────────────────────────────────────
# Maximum call recording duration in seconds (cost guardrail)
MAX_RECORDING_DURATION_SECONDS=3600
